# Example environment variables
# Copy this file to .env and fill in your actual values

# Database Configuration
# For development (local PostgreSQL via Docker): Use the connection string below
# For production (PostgreSQL): Update with your production database URL
DATABASE_URL="postgresql://pouantou_user:dev_password@localhost:5432/pouantou_dev"

# Resend API Key - Get this from https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
NEXT_PUBLIC_RESEND_API_KEY=your_resend_api_key_here

AMADEUS_API_KEY=<api-key>
AMADEUS_API_KEY_SECRET=<api-key-secret>
GMAIL_USER=<gmail-address>
GMAIL_APP_PASSWORD=<gmail-app-password>